<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.ui.AwardController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Upravljanje nagradama"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="nameField" promptText="Naziv nagrade" prefWidth="200"/>
        <TextField fx:id="yearField" promptText="Godina" prefWidth="80"/>
        <TextField fx:id="organizationField" promptText="Organizacija" prefWidth="200"/>
        <Button text="Dodaj" onAction="#handleAdd"/>
        <Button text="Ažuriraj" onAction="#handleUpdate"/>
        <Button text="Obriši" onAction="#handleDelete"/>
        <Button text="Odustani" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="400">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Naziv" prefWidth="200"/>
            <TableColumn fx:id="yearColumn" text="Godina" prefWidth="80"/>
            <TableColumn fx:id="organizationColumn" text="Organizacija" prefWidth="250"/>
        </columns>
    </TableView>

</VBox>