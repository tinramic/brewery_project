<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.ui.BrewmasterController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Upravljanje pivarima"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="nameField" promptText="Ime pivara" prefWidth="200"/>
        <TextField fx:id="bioField" promptText="Bio" prefWidth="200"/>
        <TextField fx:id="brewingPhilosophyField" promptText="Filozofija varenja" prefWidth="200"/>
        <Button text="Dodaj" onAction="#handleAdd"/>
        <Button text="Ažuriraj" onAction="#handleUpdate"/>
        <Button text="Obriši" onAction="#handleDelete"/>
        <Button text="Odustani" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="400">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Ime" prefWidth="150"/>
            <TableColumn fx:id="bioColumn" text="Bio" prefWidth="200"/>
            <TableColumn fx:id="brewingPhilosophyColumn" text="Filozofija varenja" prefWidth="250"/>
        </columns>
    </TableView>

</VBox>