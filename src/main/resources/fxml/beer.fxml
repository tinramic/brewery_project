<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.ui.BeerController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Upravljanje pivima"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <TextField fx:id="nameField" promptText="Naziv piva" prefWidth="200"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="abvField" promptText="ABV %" prefWidth="100"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <TextField fx:id="ibuField" promptText="IBU" prefWidth="100"
                   GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="srmField" promptText="SRM" prefWidth="100"
                   GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <TextField fx:id="flavorProfileField" promptText="Profil okusa" prefWidth="200"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="breweryComboBox" promptText="Pivovara" prefWidth="200"
                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <ComboBox fx:id="beerStyleComboBox" promptText="Stil piva" prefWidth="200"
                  GridPane.rowIndex="1" GridPane.columnIndex="2"/>

        <ComboBox fx:id="countryComboBox" promptText="Zemlja" prefWidth="200"
                  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="brewmasterComboBox" promptText="Pivar" prefWidth="200"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Button text="Odaberi sliku" onAction="#handleSelectImage"
                GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <Label fx:id="imagePathLabel" text="Nema slike"
               GridPane.rowIndex="2" GridPane.columnIndex="3"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Dodaj" onAction="#handleAdd"/>
        <Button text="Ažuriraj" onAction="#handleUpdate"/>
        <Button text="Obriši" onAction="#handleDelete"/>
        <Button text="Odustani" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="350">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="40"/>
            <TableColumn fx:id="nameColumn" text="Naziv" prefWidth="150"/>
            <TableColumn fx:id="abvColumn" text="ABV%" prefWidth="60"/>
            <TableColumn fx:id="ibuColumn" text="IBU" prefWidth="60"/>
            <TableColumn fx:id="srmColumn" text="SRM" prefWidth="60"/>
            <TableColumn fx:id="breweryColumn" text="Pivovara" prefWidth="150"/>
            <TableColumn fx:id="styleColumn" text="Stil" prefWidth="100"/>
            <TableColumn fx:id="countryColumn" text="Zemlja" prefWidth="100"/>
            <TableColumn fx:id="brewmasterColumn" text="Pivar" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>