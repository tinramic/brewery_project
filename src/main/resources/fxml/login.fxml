<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.ui.LoginController"
      alignment="CENTER"
      spacing="15"
      style="-fx-padding: 40; -fx-background-color: #f5f5f5;">

    <Label text="Beer Catalog"
           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <Label text="Prijava u sustav"
           style="-fx-font-size: 14; -fx-text-fill: #666;"/>

    <TextField fx:id="usernameField"
               promptText="Korisničko ime"
               prefWidth="250"/>

    <PasswordField fx:id="passwordField"
                   promptText="Lozinka"
                   prefWidth="250"/>

    <Button fx:id="loginButton"
            text="Prijava"
            prefWidth="250"
            onAction="#handleLogin"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14;"/>

    <Separator/>

    <Label text="Nemate račun?"
           style="-fx-text-fill: #666;"/>

    <Button fx:id="registerButton"
            text="Registracija"
            prefWidth="250"
            onAction="#handleRegister"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14;"/>

</VBox>